#: ../lshw.cc:24
#, c-format
msgid "usage: %s [-format] [-options ...]\n"
msgstr "použití: %s [-format] [-options ...]\n"

#: ../lshw.cc:25
#, c-format
msgid "       %s -version\n"
msgstr "       %s -version\n"

#: ../lshw.cc:27
#, c-format
msgid "\t-version        print program version (%s)\n"
msgstr "\t-version        vypsat informaci o verzi (%s)\n"

#: ../lshw.cc:28
#, c-format
msgid ""
"\n"
"format can be\n"
msgstr ""
"\n"
"formát může být\n"

#: ../lshw.cc:29
#, c-format
msgid "\t-html           output hardware tree as HTML\n"
msgstr "\t-html           vypsat strom hardware jako HTML\n"

#: ../lshw.cc:30
#, c-format
msgid "\t-xml            output hardware tree as XML\n"
msgstr "\t-html           vypsat strom hardware jako XML\r\n"

#: ../lshw.cc:31
#, c-format
msgid "\t-json           output hardware tree as a JSON object\n"
msgstr "\t-html           vypsat strom hardware jako JSON objekt\r\n"

#: ../lshw.cc:32
#, c-format
msgid "\t-short          output hardware paths\n"
msgstr "\t-short          vypsat popisy umístění hardwaru\n"

#: ../lshw.cc:33
#, c-format
msgid "\t-businfo        output bus information\n"
msgstr "\t-businfo        vypsat informace o sběrnici\n"

#: ../lshw.cc:35
#, c-format
msgid "\t-X              use graphical interface\n"
msgstr "\t-X              použít grafické rozhraní\n"

#: ../lshw.cc:36
#, c-format
msgid ""
"\n"
"options can be\n"
msgstr ""
"\n"
"volby mohou být\n"

#: ../lshw.cc:38
#, c-format
msgid ""
"\t-dump filename  display output and dump collected information into a file "
"(SQLite database)\n"
msgstr ""
"\t-dump nazev_souboru  zobrazí výstup a vypíše shromážděné informace do "
"souboru (databáze SQLite)\n"

#: ../lshw.cc:40
#, c-format
msgid "\t-class CLASS    only show a certain class of hardware\n"
msgstr "\t-class TŘÍDA    zobrazit pouze určitou třídu zařízení\n"

#: ../lshw.cc:41
#, c-format
msgid "\t-C CLASS        same as '-class CLASS'\n"
msgstr "\t-C TŘÍDA        stejné jako „-class TŘÍDA“\n"

#: ../lshw.cc:42
#, c-format
msgid "\t-c CLASS        same as '-class CLASS'\n"
msgstr "\t-c TŘÍDA        stejné jako „-class TŘÍDA“\r\n"

#: ../lshw.cc:44
#, c-format
msgid "\t-disable TEST   disable a test (like pci, isapnp, cpuid, etc.)\n"
msgstr "\t-disable TEST   zakázat test (např. pci, isapnp, cpuid, atd.)\n"

#: ../lshw.cc:46
#, c-format
msgid "\t-enable TEST    enable a test (like pci, isapnp, cpuid, etc.)\n"
msgstr "\t-enable TEST    povolit test (např. pci, isapnp, cpuid, adt.)\n"

#: ../lshw.cc:47
#, c-format
msgid "\t-quiet          don't display status\n"
msgstr "\t-quiet          nezobrazovat stav\n"

#: ../lshw.cc:48
#, c-format
msgid ""
"\t-sanitize       sanitize output (remove sensitive information like serial "
"numbers, etc.)\n"
msgstr ""
"\t-sanitize       „dezinfikovat“ výstup (odebrat citlivé informace jako "
"např. sériová čísla, atp.)\n"

#: ../lshw.cc:49
#, c-format
msgid "\t-numeric        output numeric IDs (for PCI, USB, etc.)\n"
msgstr "\t-numeric        vypsat číselné identifikátory (pro PCI, USB, atp.)\n"

#: ../lshw.cc:50
#, c-format
msgid ""
"\t-notime         exclude volatile attributes (timestamps) from output\n"
msgstr ""
"\t-notime         vynechat z výstupu proměnlivé atributy (časová razítka)\n"

#: ../lshw.cc:126
#, c-format
msgid "the latest version is %s\n"
msgstr "nejnovější verze je %s\n"

#: ../lshw.cc:228
#, c-format
msgid "WARNING: you should run this program as super-user.\n"
msgstr "VAROVÁNÍ: tato aplikace by měla být spouštěna s oprávněními správce.\n"

#: ../lshw.cc:259
#, c-format
msgid ""
"WARNING: output may be incomplete or inaccurate, you should run this program "
"as super-user.\n"
msgstr ""
"VAROVÁNÍ: výstup může být neúplný nebo nepřesný – tento program by měl být "
"spouštěn s oprávněními správce.\n"
